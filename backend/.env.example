# Rename this file to .env and fill in your actual values
# Never commit the real .env file to GitHub

# watsonx Orchestrate (Use Case 1)
# WXO_API_KEY accepts either:
# 1) IBM Cloud IAM API key (backend will exchange it for access token automatically), or
# 2) Direct bearer/JWT token if your setup provides one.
# For watsonx Orchestrate instances configured via `orchestrate env ... --type mcsp`,
# set WXO_AUTH_TYPE=mcsp (default).
WXO_API_KEY=your_watsonx_api_key_here
WXO_INSTANCE_ID=your_instance_id_here
WXO_AGENT_ID=your_agent_id_here
WXO_AUTH_TYPE=mcsp
# Optional overrides for advanced auth scenarios
# IBM_IAM_URL=https://iam.cloud.ibm.com
# IBM_MCSP_IAM_URL=https://iam.platform.saas.ibm.com
# IBM_MCSP_V2_IAM_URL=https://account-iam.platform.saas.ibm.com
# Region options: us-south, eu-gb, eu-de, au-syd
WXO_REGION=us-south

# Anthropic (Use Case 2 mileage parsing)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets (Use Case 2 mileage log)
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Path to your downloaded Google service account JSON key
GOOGLE_CREDENTIALS_PATH=./google_credentials.json
